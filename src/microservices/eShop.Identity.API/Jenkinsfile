env.IMAGE_NAME = "ahmniab/eshop-identity-api"
// VERSION = sh(script: "git rev-parse --short HEAD", returnStdout: true).trim()

stage('Run Tests for Identity API') {
    sh """
    docker run --rm \
        -v "${WORKSPACE}/src/microservices/eShop.Identity.API:/app:z" \
        -w /app \
        -e DOTNET_CLI_HOME=/app/.dotnet-temp \
        mcr.microsoft.com/dotnet/sdk:10.0 \
        dotnet test eShop.Identity.API.sln
    """

}

stage('Build and Push Identity API Image') {
    sh "docker build -t ${env.IMAGE_NAME}:${env.VERSION} src/microservices/eShop.Identity.API"
    sh "docker push ${env.IMAGE_NAME}:${env.VERSION}"
}
